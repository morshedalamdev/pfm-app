# FastAPI foundation environment template.
# Copy to .env for local development and keep real values out of Git.

APP_NAME="PFM API"
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","https://pfm.morshedalam.dev"]'
DATABASE_URL=postgresql+asyncpg://pfm_app@localhost:5432/pfm_app
# Optional direct PostgreSQL URL used only by Alembic. Production deployments
# with a pooled DATABASE_URL should set this to the provider's direct endpoint.
# To use Neon locally after rotating the exposed password, replace the two
# values above with the pooled and direct connection strings from Neon:
# DATABASE_URL=postgresql://USER:URL_ENCODED_PASSWORD@POOLER_HOST/DB?sslmode=require&channel_binding=require
# MIGRATION_DATABASE_URL=postgresql://USER:URL_ENCODED_PASSWORD@DIRECT_HOST/DB?sslmode=require&channel_binding=require
MIGRATION_DATABASE_URL=
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
ACCESS_TOKEN_SECRET_KEY=replace-with-a-long-random-local-secret
ACCESS_TOKEN_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_SECRET_KEY=replace-with-another-long-random-local-secret
REFRESH_TOKEN_EXPIRE_DAYS=30
RECURRING_WORKER_BATCH_SIZE=25
RECURRING_WORKER_LOCK_SECONDS=60
RECURRING_WORKER_POLL_SECONDS=30
OUTBOX_WORKER_BATCH_SIZE=25
OUTBOX_WORKER_LOCK_SECONDS=60
OUTBOX_WORKER_MAX_BACKOFF_SECONDS=300
OUTBOX_WORKER_POLL_SECONDS=30
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=.local/storage
EMAIL_BACKEND=console
EMAIL_FROM_ADDRESS=no-reply@localhost
RECEIPT_MAX_UPLOAD_BYTES=5242880
RECEIPT_ALLOWED_CONTENT_TYPES='["application/pdf","image/jpeg","image/png","image/webp"]'
PORT=8000
RUN_MIGRATIONS=false

# Direct OAuth 2.0 / OpenID Connect sign-in. Keep all secret values out of Git.
# Local GitHub credentials belong to the GitHub OAuth App whose callback is:
# http://localhost:8000/api/v1/auth/oauth/github/callback
# Google may use one Web OAuth client with the local and production callback URLs.
FRONTEND_BASE_URL=http://localhost:3000
OAUTH_PUBLIC_API_URL=http://localhost:8000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_STATE_SECRET_KEY=
OAUTH_REGISTRATION_TICKET_SECRET_KEY=
OAUTH_REGISTRATION_TICKET_EXPIRE_MINUTES=10
OAUTH_LOGIN_EXCHANGE_EXPIRE_SECONDS=60
OAUTH_LINK_INTENT_EXPIRE_SECONDS=300

# Production object-storage, SMTP, or transactional-email provider variables are
# intentionally omitted until a provider adapter is selected. Local development
# must continue to work with STORAGE_BACKEND=local and EMAIL_BACKEND=console.
